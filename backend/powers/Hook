-- ============================ CONSTANTES DE DISEÑO VFX ============================
local LIGHT_FLICKER_FREQ = 12       -- Hz
local LIGHT_SATURATION_BOOST = 1.2  -- 20% más saturado que el color base
local PARTICLE_BURST_COUNT = 24     -- Número de partículas por ráfaga (evita overdraw)
local MESH_ALPHA_MASK_ID = "rbxassetid://128576183" -- Ejemplo: textura con degradado circular
local FORCEFIELD_MATERIAL = Enum.Material.ForceField
local NEON_MATERIAL = Enum.Material.Neon

-- Sonidos (IDs placeholder, reemplazar por los deseados)
local SOUND_CHAIN_THROW = "rbxassetid://9121902154"
local SOUND_IMPACT_BLOOD = "rbxassetid://9121903071"
local SOUND_DRAG = "rbxassetid://9121904355"

-- ============================ UTILIDADES DE SEGURIDAD ============================
local function safeCleanup(instance: Instance?, delaySeconds: number?)
	if not instance then return end
	if delaySeconds then
		task.delay(delaySeconds, function()
			if instance and instance.Parent then
				instance:Destroy()
			end
		end)
	else
		if instance.Parent then instance:Destroy() end
	end
end

-- ============================ HERRAMIENTAS GEOMÉTRICAS ============================
local Geometry = {}

-- Alineación de CFrame con la normal de una superficie (usando Raycast)
function Geometry.alignToSurface(position: Vector3, direction: Vector3?): CFrame?
	local rayOrigin = position
	local rayDirection = direction or Vector3.new(0, -10, 0) -- Por defecto hacia abajo
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Blacklist
	rayParams.FilterDescendantsInstances = {Players.LocalPlayer.Character} -- Evitar self-hit

	local result = Workspace:Raycast(rayOrigin, rayDirection, rayParams)
	if result then
		local normal = result.Normal
		local upVector = normal
		local rightVector = (math.abs(normal.Y) < 0.99) and Vector3.new(0,1,0):Cross(normal).Unit or Vector3.new(1,0,0)
		local lookVector = rightVector:Cross(upVector).Unit
		return CFrame.fromMatrix(result.Position, rightVector, upVector, lookVector)
	end
	return nil
end

-- ============================ FACTORÍA DE MESHES PROCEDURALES ============================
local MeshFactory = {}

-- Crea un MeshPart con material y opcionalmente un mapa de opacidad (alpha mask)
function MeshFactory.createEnergyMesh(shape: string, size: Vector3, color: Color3, position: CFrame, parent: Instance?): MeshPart
	local mesh = Instance.new("MeshPart")
	mesh.Size = size
	mesh.Color = color
	mesh.Material = FORCEFIELD_MATERIAL
	mesh.Anchored = true
	mesh.CanCollide = false
	mesh.CFrame = position
	mesh.Transparency = 0.2

	-- Aplicar mesh procedural (Built-in shapes)
	local meshId = "rbxassetid://" .. (shape == "Cylinder" and "1033714" or "1033710") -- Cylinder / Sphere
	local specialMesh = Instance.new("SpecialMesh")
	specialMesh.MeshId = meshId
	specialMesh.Scale = Vector3.new(1,1,1)
	specialMesh.Parent = mesh

	-- Textura de opacidad (alpha mask) para bordes suaves
	local surfaceGui = Instance.new("SurfaceGui")
	surfaceGui.Face = Enum.NormalId.Front
	surfaceGui.AlwaysOnTop = true
	surfaceGui.Brightness = 0
	surfaceGui.Transparency = 0
	surfaceGui.ClipsDescendants = false
	surfaceGui.Parent = mesh

	local imageLabel = Instance.new("ImageLabel")
	imageLabel.Size = UDim2.new(1,0,1,0)
	imageLabel.BackgroundTransparency = 1
	imageLabel.Image = MESH_ALPHA_MASK_ID
	imageLabel.ImageTransparency = 0.5
	imageLabel.ScaleType = Enum.ScaleType.Stretch
	imageLabel.Parent = surfaceGui

	mesh.Parent = parent or Workspace
	return mesh
end

-- ============================ SISTEMA DE PARTÍCULAS (Burst-Driven) ============================
local ParticleSystem = {}

-- Configura un emisor con secuencias no lineales (Bezier)
function ParticleSystem.configureEmitter(emitter: ParticleEmitter, baseColor: Color3)
	-- Curva de tamaño: Ease-in-out con puntos clave (Bezier implícito vía NumberSequence)
	local sizeSeq = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 0.2, 0.8),
		NumberSequenceKeypoint.new(0.2, 1.2, -0.5),
		NumberSequenceKeypoint.new(0.6, 0.9, -1),
		NumberSequenceKeypoint.new(1, 0, -0.3)
	}
	emitter.Size = sizeSeq

	-- Curva de transparencia: A mayor tamaño, mayor transparencia (lock size-transparency)
	local transSeq = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 0, 0.5),
		NumberSequenceKeypoint.new(0.3, 0.2, 0.2),
		NumberSequenceKeypoint.new(0.7, 0.7, 0.5),
		NumberSequenceKeypoint.new(1, 1, 0.3)
	}
	emitter.Transparency = transSeq

	emitter.Color = ColorSequence.new(baseColor)
	emitter.Rate = 0                     -- Deshabilitado, usamos :Emit()
	emitter.Lifetime = NumberRange.new(0.8, 1.2)
	emitter.Speed = NumberRange.new(6, 12)
	emitter.SpreadAngle = Vector2.new(15, 30)
	emitter.RotSpeed = NumberRange.new(-180, 180)
	emitter.Acceleration = Vector3.new(0, 5, 0)
	emitter.Drag = 2
	emitter.LockedToPart = false
	emitter.Enabled = true              -- Se mantiene Enabled pero sin emisión continua
	emitter.VelocityInheritance = 0.2
end

-- Dispara una ráfaga de partículas en una posición
function ParticleSystem.emitBurst(position: Vector3, count: number, color: Color3, parent: Instance?)
	local attachment = Instance.new("Attachment")
	attachment.WorldPosition = position
	attachment.Parent = parent or Workspace.Terrain

	local emitter = Instance.new("ParticleEmitter")
	emitter.Parent = attachment
	ParticleSystem.configureEmitter(emitter, color)

	-- Ráfaga única
	emitter:Emit(count)

	-- Limpieza automática tras tiempo de vida máximo
	task.delay(emitter.Lifetime.Max + 0.5, function()
		safeCleanup(attachment)
	end)
end

-- ============================ ILUMINACIÓN DINÁMICA (Sinusoidal Flicker) ============================
local LightingEffects = {}

function LightingEffects.createFlickerLight(position: Vector3, baseColor: Color3, range: number, parent: Instance?)
	local light = Instance.new("PointLight")
	light.Position = position
	light.Color = baseColor:Lerp(Color3.new(1,1,1), 0.2) -- 20% más saturado
	light.Range = range
	light.Brightness = 4
	light.Shadows = false
	light.Parent = parent or Workspace

	-- Flicker sinusoidal
	local connection
	local startTime = os.clock()
	connection = RunService.Heartbeat:Connect(function()
		if not light.Parent then
			connection:Disconnect()
			return
		end
		local t = os.clock() - startTime
		local flicker = 0.7 + 0.5 * math.sin(t * LIGHT_FLICKER_FREQ)
		light.Brightness = math.clamp(4 * flicker, 1, 6)
	end)

	-- Desconexión programada y limpieza
	task.delay(2.5, function()
		if connection then connection:Disconnect() end
		safeCleanup(light)
	end)

	return light
end

-- ============================ INTERPOLACIÓN KINÉTICA (Weight-Based Scaling) ============================
local TweenEffects = {}

-- Escala un objeto con easing exponencial y sincroniza transparencia
function TweenEffects.scaleAndFade(obj: BasePart, targetScale: Vector3, duration: number, callback: (() -> ())?)
	local originalSize = obj.Size
	local originalTransparency = obj.Transparency

	local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
	local tween = TweenService:Create(obj, tweenInfo, {
		Size = targetScale,
		Transparency = 1 - (originalSize.Magnitude / targetScale.Magnitude) * (1 - originalTransparency)
	})

	tween:Play()
	if callback then
		tween.Completed:Connect(callback)
	end
	return tween
end

-- ============================ COMPONENTE PRINCIPAL DE VFX PARA LA HABILIDAD ============================
local VFXChain = {}

-- Efecto de cadena helicoidal usando MeshParts (alineados proceduralmente)
function VFXChain.createSpiralChain(startPos: Vector3, endPos: Vector3, turns: number, radius: number, duration: number)
	local dir = endPos - startPos
	local length = dir.Magnitude
	local unit = dir.Unit
	local perpX = (math.abs(unit.Y) < 0.99) and unit:Cross(Vector3.new(0,1,0)).Unit or unit:Cross(Vector3.new(1,0,0)).Unit
	local perpZ = unit:Cross(perpX).Unit

	local segments = math.floor(length * 2) + 6
	local meshes = {}

	for i = 0, segments do
		local t = i / segments
		local angle = t * math.pi * 2 * turns

		local offset = perpX * math.cos(angle) * radius + perpZ * math.sin(angle) * radius
		local pos = startPos + unit * (t * length) + offset

		local mesh = MeshFactory.createEnergyMesh(
			"Cylinder",
			Vector3.new(0.25, 0.25, 0.25),
			Color3.fromRGB(200, 40, 40),
			CFrame.new(pos),
			Workspace
		)
		table.insert(meshes, mesh)
	end

	-- Fade out sincronizado con escala y transparencia
	task.delay(duration, function()
		for _, mesh in ipairs(meshes) do
			TweenEffects.scaleAndFade(mesh, Vector3.new(0,0,0), 0.4, function()
				mesh:Destroy()
			end)
		end
	end)
end

-- Efecto de impacto con alineación a la normal (si hay superficie)
function VFXChain.createImpactDecal(position: Vector3, normal: Vector3?)
	local alignedCFrame: CFrame
	if normal then
		local right = (math.abs(normal.Y) < 0.99) and Vector3.new(0,1,0):Cross(normal).Unit or Vector3.new(1,0,0)
		local look = right:Cross(normal).Unit
		alignedCFrame = CFrame.fromMatrix(position, right, normal, look)
	else
		alignedCFrame = CFrame.new(position)
	end

	-- Mesh de impacto (onda de choque)
	local shockwave = MeshFactory.createEnergyMesh(
		"Cylinder",
		Vector3.new(0.5, 0.1, 0.5),
		Color3.fromRGB(255, 80, 80),
		alignedCFrame,
		Workspace
	)
	shockwave.Material = NEON_MATERIAL

	TweenEffects.scaleAndFade(shockwave, Vector3.new(6, 0.1, 6), 0.5, function()
		shockwave:Destroy()
	end)

	-- Partículas de impacto (ráfaga)
	ParticleSystem.emitBurst(position, PARTICLE_BURST_COUNT, Color3.fromRGB(220, 30, 30), Workspace)

	-- Luz de impacto con flicker
	LightingEffects.createFlickerLight(position, Color3.fromRGB(255, 70, 70), 12, Workspace)
end

