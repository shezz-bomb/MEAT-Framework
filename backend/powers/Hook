-- Módulo exportable que reemplaza la lógica VFX original
export type PowerVFXModule = {
	playChainThrow: (player: Player, targetPosition: Vector3) -> (),
	playChainImpact: (player: Player, targetPosition: Vector3, hitNormal: Vector3?) -> (),
	cleanup: () -> ()
}

local PowerChainVFX: PowerVFXModule = {} :: any

function PowerChainVFX.playChainThrow(player: Player, targetPosition: Vector3)
	local character = player.Character
	if not character then return end
	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- Sonido 3D
	local soundPart = Instance.new("Part")
	soundPart.Anchored = true
	soundPart.CanCollide = false
	soundPart.Transparency = 1
	soundPart.Size = Vector3.new(1,1,1)
	soundPart.Position = root.Position
	soundPart.Parent = Workspace
	local sound = Instance.new("Sound", soundPart)
	sound.SoundId = SOUND_CHAIN_THROW
	sound.Volume = 0.8
	sound:Play()
	Debris:AddItem(soundPart, sound.TimeLength + 0.5)

	-- Cadena helicoidal (MeshPart procedural)
	VFXChain.createSpiralChain(root.Position, targetPosition, 1.8, 1.4, 0.45)

	-- Luz de lanzamiento
	LightingEffects.createFlickerLight(root.Position, Color3.fromRGB(255, 100, 100), 8, Workspace)
end

function PowerChainVFX.playChainImpact(player: Player, targetPosition: Vector3, hitNormal: Vector3?)
	-- Efecto de sangre/impacto alineado a la normal si es proporcionada
	VFXChain.createImpactDecal(targetPosition, hitNormal)

	-- Sonido de impacto
	local soundPart = Instance.new("Part")
	soundPart.Anchored = true
	soundPart.CanCollide = false
	soundPart.Transparency = 1
	soundPart.Size = Vector3.new(1,1,1)
	soundPart.Position = targetPosition
	soundPart.Parent = Workspace
	local sound = Instance.new("Sound", soundPart)
	sound.SoundId = SOUND_IMPACT_BLOOD
	sound.Volume = 1
	sound.PlaybackSpeed = 1.1
	sound:Play()
	Debris:AddItem(soundPart, sound.TimeLength + 0.5)

	-- Ráfaga de partículas adicional (sangre)
	ParticleSystem.emitBurst(targetPosition + Vector3.new(0,1,0), 16, Color3.fromRGB(150, 0, 0), Workspace)
end

function PowerChainVFX.cleanup()
	-- Cualquier limpieza global necesaria
end

