--!strict
local RelicsManager = {}
local Players          = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local RS               = game:GetService("ReplicatedStorage")

local AUTO_SAVE_INTERVAL = 300
local MAX_RETRIES        = 5
local RETRY_DELAY        = 2

type RelicDef = { name: string, description: string?, rarity: string, dropWeight: number }
type SessionEntry = { data: {[string]: number}, dirty: boolean, lockKey: string }

local RELICS: {[string]: RelicDef} = {
	CarneDeQu       = { name="🜁 Carne de Qu",        description="Un fragmento de dios. Late con violencia.", rarity="legendario", dropWeight=5  },
	FragmentoDios   = { name="⚡ Fragmento de Dios",   description="Poder condensado.",                         rarity="legendario", dropWeight=3  },
	ADNPterosapiens = { name="🧬 ADN Pterosapiens",    description="Respiras agua solo de pensarlo.",           rarity="raro",       dropWeight=15 },
	ADNTemerario    = { name="🔥 ADN Temerario",       description="Corre o muere.",                            rarity="raro",       dropWeight=15 },
	ADNToolBreeder  = { name="⚙️ ADN ToolBreeder",     description="Construyes sin pensar.",                    rarity="raro",       dropWeight=15 },
	ADNColonial     = { name="🐛 ADN Colonial",        description="Eres parte de algo mayor.",                 rarity="raro",       dropWeight=15 },
	FragmentoHueso  = { name="🦴 Fragmento de Hueso",  description="Restos de algo que fue vivo.",              rarity="común",      dropWeight=50 },
	MetalOxidado    = { name="🔩 Metal Oxidado",       description="Herrumbre y memoria.",                      rarity="común",      dropWeight=60 },
	CarneComun      = { name="🥩 Carne Común",         description="La moneda de los vivos.",                   rarity="común",      dropWeight=80 },
}	

-- Drop pool ponderado
local DROP_POOL: {string} = {}
for id, data in pairs(RELICS) do
	for _ = 1, data.dropWeight do
		table.insert(DROP_POOL, id)
	end
end

local sessionData: {[number]: SessionEntry} = {}

local function getDataStore(userId: number)
	return DataStoreService:GetDataStore("RelicsData_" .. math.floor(userId / 10000))
end

local function savePlayerData(userId: number): boolean
	local entry = sessionData[userId]
	if not entry or not entry.dirty then return true end
	local store = getDataStore(userId)
	local success, err = pcall(function()
		store:UpdateAsync(tostring(userId), function(old)
			if old and old.lock and old.lock ~= entry.lockKey then error("Lock perdido") end
			return { relics = entry.data, lock = entry.lockKey, version = (old and old.version or 0) + 1 }
		end)
	end)
	if success then entry.dirty = false else warn("Error guardando:", err) end
	return success
end

local function loadPlayerData(player: Player)
	local userId   = player.UserId
	local store    = getDataStore(userId)
	local lockKey  = game.JobId .. "_" .. userId
	for retry = 0, MAX_RETRIES do
		local success, data = pcall(function()
			return store:UpdateAsync(tostring(userId), function(old)
				if not old then return { relics = {}, lock = lockKey, version = 1 } end
				if old.lock and old.lock ~= lockKey then
				-- Lock de servidor anterior muerto, sobreescribir
				warn("⚠️ Session lock sobreescrito para " .. tostring(userId) .. " — servidor anterior caído")
			end
				old.lock    = lockKey
				old.version = (old.version or 0) + 1
				return old
			end)
		end)
		if success and data then
			sessionData[userId] = { data = data.relics or {}, dirty = false, lockKey = lockKey }
			RelicsManager:syncToClient(player)
			return
		elseif success and data == nil then
			player:Kick("Sesión activa en otro servidor.")
			return
		else
			warn("Error cargando datos (intento", retry+1, "):", tostring(data))
			task.wait(RETRY_DELAY)
		end
	end
	player:Kick("No se pudieron cargar tus datos.")
end

function RelicsManager:init()
	task.spawn(function()
		while true do
			task.wait(AUTO_SAVE_INTERVAL)
			for _, player in ipairs(Players:GetPlayers()) do
				local entry = sessionData[player.UserId]
				if entry and entry.dirty then
					task.spawn(savePlayerData, player.UserId)
				end
			end
		end
	end)
	Players.PlayerAdded:Connect(loadPlayerData)
	Players.PlayerRemoving:Connect(function(player)
		local userId = player.UserId
		savePlayerData(userId)
		sessionData[userId] = nil
	end)
end

function RelicsManager:getRelicCount(player: Player, relicId: string): number
	local entry = sessionData[player.UserId]
	return entry and (entry.data[relicId] or 0) or 0
end

function RelicsManager:giveRelic(player: Player, relicId: string, amount: number): boolean
	if amount <= 0 then return false end
	local entry = sessionData[player.UserId]
	if not entry then return false end
	entry.data[relicId] = (entry.data[relicId] or 0) + amount
	entry.dirty = true
	self:syncToClient(player)
	return true
end

function RelicsManager:takeRelic(player: Player, relicId: string, amount: number): boolean
	if amount <= 0 then return true end
	local entry = sessionData[player.UserId]
	if entry and (entry.data[relicId] or 0) >= amount then
		entry.data[relicId] = entry.data[relicId] - amount
		entry.dirty = true
		self:syncToClient(player)
		return true
	end
	return false
end

function RelicsManager:transferRelic(from: Player, to: Player, relicId: string, amount: number): boolean
	if amount <= 0 then return false end
	local fromE = sessionData[from.UserId]
	local toE   = sessionData[to.UserId]
	if fromE and toE and (fromE.data[relicId] or 0) >= amount then
		fromE.data[relicId] = fromE.data[relicId] - amount
		toE.data[relicId]   = (toE.data[relicId] or 0) + amount
		fromE.dirty = true
		toE.dirty   = true
		self:syncToClient(from)
		self:syncToClient(to)
		return true
	end
	return false
end

function RelicsManager:syncToClient(player: Player)
	local entry = sessionData[player.UserId]
	if not entry then return end
	local event = RS:FindFirstChild("RelicUpdate") :: RemoteEvent?
	if event then event:FireClient(player, entry.data) end
end

function RelicsManager:getRelicInfo(relicId: string): RelicDef?
	return RELICS[relicId]
end

function RelicsManager:getAllRelicDefinitions(): {[string]: RelicDef}
	return RELICS
end

local function getDayMultiplier(): number
	local ok, CalSvc = pcall(require, game.ServerScriptService.Core.Director.CalendarService.CalendarService)
	if not ok then return 1 end
	local mod = CalSvc:getActiveModule()
	return (mod and mod.relicMultiplier) or 1
end

function RelicsManager:onPlayerKilled(victim: Player, killer: Player?)
	if not victim or not killer then return end
	local victimEntry = sessionData[victim.UserId]
	local killerEntry = killer and sessionData[killer.UserId]
	if not victimEntry or not killerEntry then return end

	local multiplier = getDayMultiplier()
	local dropped: {{id: string, amount: number}} = {}
	local lostCount = math.random(1, 3)

	for relicId, amount in pairs(victimEntry.data) do
		if amount > 0 and lostCount > 0 then
			local lose = math.min(amount, math.max(1, math.floor(amount * 0.3)))
			victimEntry.data[relicId] = amount - lose
			victimEntry.dirty = true
			table.insert(dropped, { id = relicId, amount = lose })
			lostCount -= 1
		end
	end

	for _, drop in ipairs(dropped) do
		local gained = math.max(1, math.floor(drop.amount * multiplier))
		killerEntry.data[drop.id] = (killerEntry.data[drop.id] or 0) + gained
		killerEntry.dirty = true
	end

	killer:SetAttribute("Kills", (killer:GetAttribute("Kills") or 0) + 1)
	self:syncToClient(victim)
	self:syncToClient(killer)

	if #dropped > 0 then
		local info = RELICS[dropped[1].id]
		local relicName = info and info.name or dropped[1].id
		local msg = string.format("💀 [%s] eliminó a [%s] | %s", killer.Name, victim.Name, relicName)
		local m = Instance.new("Message")
		m.Text = msg
		m.Parent = workspace
		task.delay(6, function() if m and m.Parent then m:Destroy() end end)
	end
end

function RelicsManager:dropRandom(player: Player, count: number?)
	count = count or 1
	local total = math.floor((count :: number) * getDayMultiplier())
	local entry = sessionData[player.UserId]
	if not entry then return end
	for _ = 1, total do
		local relicId = DROP_POOL[math.random(#DROP_POOL)]
		entry.data[relicId] = (entry.data[relicId] or 0) + 1
		entry.dirty = true
	end
	self:syncToClient(player)
end

return RelicsManager
