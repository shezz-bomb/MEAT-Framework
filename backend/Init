local DirectorMonitor  = require(script.Parent.Core.Director.DirectorMonitor)
local DirectorDecider  = require(script.Parent.Core.Director.DirectorDecider)
local DirectorExecutor = require(script.Parent.Core.Director.DirectorExecutor)
local CalendarService  = require(script.Parent.Core.Director.CalendarService.CalendarService)
local BiomeDetector    = require(script.Parent.Core.Evolution.BiomeDetector)
local CypherManager    = require(script.Parent.Core.CypherManager)
local RelicsManager    = require(script.Parent.Core.Economy.RelicsManager)
local DuelManager      = require(script.Parent.Core.Arena.DuelManager)
local MysteryBoxes     = require(script.Parent.Core.Economy.MysteryBoxes)
local TradingSystem    = require(script.Parent.Core.Economy.TradingSystem)
local ArenaEvents      = require(script.Parent.Core.Arena.ArenaEvents)
local CombatManager    = require(script.Parent.Core.Combat.CombatManager)
